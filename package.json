{
  "name": "@xhubio/bitdiver-runner",
  "version": "0.1.0",
  "private": true,
  "main": "dist/src/index.js",
  "types": "dist/src/index.d.ts",
  "files": ["dist/src/**/*.*"],
  "scripts": {
    "build": "npm run check && rm -rf dist && tsc",
    "check": "biome check --write .",
    "format": "biome format --write .",
    "lint": "biome lint .",
    "ci:check": "biome ci .",
    "ci:build": "npm run ci:check && rm -rf dist && tsc",
    "ci:test": "npm run ci:build && vitest run",
    "test": "npm run format && npm run lint && npm run build && vitest run",
    "test:only": "vitest run",
    "test:watch": "vitest"
  },
  "license": "DBISL",
  "dependencies": {
    "@aikotools/datacompare": "file:../../aikotools/datacompare",
    "arangojs": "6.14.0",
    "luxon": "3.7.2",
    "md5": "2.2.1",
    "ts-progress": "0.1.8",
    "uuid": "9.0.1",
    "zod": "^3.23.0"
  },
  "devDependencies": {
    "@biomejs/biome": "^1.9.0",
    "@types/luxon": "3.7.1",
    "@types/node": "18.19.130",
    "@types/uuid": "9.0.8",
    "globby": "11.1.0",
    "typescript": "^5.6.0",
    "vitest": "^3.2.0"
  }
}
