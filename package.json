{
  "name": "@xhubio/bitdiver-runner",
  "version": "0.0.0-sematic-release",
  "publishConfig": {
    "access": "public"
  },
  "main": "dist/src/index.js",
  "types": "dist/src/index.d.ts",
  "files": [
    "dist/src/**/*.*"
  ],
  "scripts": {
    "build": "npm run check && rm -rf dist && tsc",
    "check": "biome check --write .",
    "format": "biome format --write .",
    "lint": "biome lint .",
    "ci:check": "biome ci .",
    "ci:build": "npm run ci:check && rm -rf dist && tsc",
    "ci:test": "npm run ci:build && vitest run",
    "test": "npm run format && npm run lint && npm run build && vitest run",
    "test:only": "vitest run",
    "test:watch": "vitest"
  },
  "license": "MIT",
  "dependencies": {
    "@aikotools/datacompare": "1.3.1",
    "arangojs": "10.2.2",
    "luxon": "3.7.2",
    "md5": "2.3.0",
    "ts-progress": "0.1.9",
    "uuid": "13.0.0",
    "zod": "4.3.6"
  },
  "devDependencies": {
    "@biomejs/biome": "2.4.10",
    "@semantic-release/git": "10.0.1",
    "@semantic-release/npm": "13.1.5",
    "@semantic-release/release-notes-generator": "14.1.0",
    "@types/luxon": "3.7.1",
    "@types/node": "25.7.0",
    "semantic-release": "25.0.3",
    "typescript": "6.0.2",
    "vitest": "4.1.3"
  }
}